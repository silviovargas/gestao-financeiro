# ─────────────────────────────────────────────────────────
# Gestão Financeira — Configuração
# Copie para .env e preencha os valores
# ─────────────────────────────────────────────────────────

# Domínio onde o sistema vai rodar
DOMAIN=gestao.exemplo.com.br

# E-mail para certificado SSL (Let's Encrypt)
EMAIL=seuemail@exemplo.com.br

# Credenciais do administrador inicial
ADMIN_EMAIL=admin@gestao.com
ADMIN_PASSWORD=123456

# Chave secreta para JWT — TROQUE por uma string aleatória longa!
JWT_SECRET=troque-esta-chave-por-algo-seguro-e-aleatorio

# Nome do sistema (aparece no sidebar)
APP_NAME=Gestão Financeira
